# ---- Trakt ----
# Create an application at https://trakt.tv/oauth/applications to obtain these.
# These seed the runtime settings store on first start; afterwards the Trakt
# connection (credentials, device auth, and lists) is managed from the dashboard
# Settings page, so configuring it entirely in the UI is also supported.
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
# Your Trakt username, or 'me'.
TRAKT_USER=me
# Legacy single list; used only when TRAKT_LISTS is empty.
TRAKT_LIST_ID=watchlist
# Comma-separated list slugs to sync, e.g. movies,tv,anime.
TRAKT_LISTS=

# ---- Services (URL + API key; seed the store, then managed in the UI) ----
JELLYSEERR_URL=http://192.168.0.x:5055
JELLYSEERR_API_KEY=
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=

# ---- TMDB (themoviedb.org; API key only, fixed public endpoint) ----
# A v3 API key or a v4 read-access token.
TMDB_API_KEY=

# ---- OMDb (omdbapi.com; API key only, fixed public endpoint) ----
OMDB_API_KEY=

# ---- SABnzbd (URL + API key) ----
# URL e.g. http://192.168.0.x:8080
SABNZBD_URL=
SABNZBD_API_KEY=

# ---- qBittorrent (URL + WebUI API key; requires qBittorrent >= 5.2.0) ----
# Generate the key in qBittorrent's Web UI settings (Authentication -> API keys).
# URL e.g. http://192.168.0.x:8080
QBITTORRENT_URL=
QBITTORRENT_API_KEY=

# ---- Sync behaviour ----
SYNC_INTERVAL_MIN=15
WEBHOOK_PORT=3223

# DRY_RUN=true logs what it *would* do (request in Jellyseerr, remove from Trakt)
# without performing any write. Keep this ON until you have verified the loop.
DRY_RUN=true

# ---- Runtime ----
TZ=Europe/Istanbul
LOG_LEVEL=INFO

# ---- Persistence (mounted to a Docker volume) ----
DB_PATH=data/aio-arr.db
TOKEN_STORE_PATH=data/trakt_tokens.json
SETTINGS_STORE_PATH=data/app_settings.json
# Disk cache for poster thumbnails (TMDB/OMDb), so each is downloaded only once.
POSTER_CACHE_PATH=data/posters
