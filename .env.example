# ---- Trakt ----
# Create an application at https://trakt.tv/oauth/applications to obtain these.
# These seed the runtime settings store on first start; afterwards the Trakt
# connection (credentials and device auth) is managed from the dashboard Settings
# page, so configuring it entirely in the UI is also supported. The connected
# account is always addressed as 'me', and the lists to sync are chosen from the
# dashboard (discovered from the account, or added by URL).
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# ---- Services (URL + API key; seed the store, then managed in the UI) ----
SEER_URL=http://192.168.0.x:5055
SEER_API_KEY=
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=

# ---- TMDB (themoviedb.org; API key only, fixed public endpoint) ----
# A v3 API key or a v4 read-access token.
TMDB_API_KEY=

# ---- OMDb (omdbapi.com; API key only, fixed public endpoint) ----
OMDB_API_KEY=

# ---- SABnzbd (URL + API key) ----
# URL e.g. http://192.168.0.x:8080
SABNZBD_URL=
SABNZBD_API_KEY=

# ---- qBittorrent (URL + WebUI API key; requires qBittorrent >= 5.2.0) ----
# Generate the key in qBittorrent's Web UI settings (Authentication -> API keys).
# URL e.g. http://192.168.0.x:8080
QBITTORRENT_URL=
QBITTORRENT_API_KEY=

# ---- Sync behaviour ----
SYNC_INTERVAL_MIN=15
WEBHOOK_PORT=3223

# ---- Bandwidth-Controllarr ----
# When true, SABnzbd is paused while qBittorrent has active torrents and resumed
# when torrents go idle. Defaults to false so the external-state side effect is
# opt-in; the switch can also be toggled from the dashboard.
BANDWIDTH_CONTROL_ENABLED=false
# How often the control loop checks qBittorrent and SABnzbd, in seconds.
# Allowed values: 10, 15, 30, 60.
BANDWIDTH_CHECK_INTERVAL_SEC=15

# ---- Runtime ----
TZ=Europe/Istanbul
LOG_LEVEL=INFO

# ---- Persistence (mounted to a Docker volume) ----
DB_PATH=data/aio-arr.db
TOKEN_STORE_PATH=data/trakt_tokens.json
SETTINGS_STORE_PATH=data/app_settings.json
# Disk cache for poster thumbnails (TMDB/OMDb), so each is downloaded only once.
POSTER_CACHE_PATH=data/posters
